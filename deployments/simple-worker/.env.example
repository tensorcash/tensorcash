# Simple Worker Configuration
# Copy this file to .env and fill in your values

# === REQUIRED: Broker Connection ===
# Get these from your TensorCash provider dashboard
BROKER_WS_URL=wss://broker.tensorcash.io/v1/ws
PROVIDER_JWT_TOKEN=eyJ...your-jwt-token...

# === Model Configuration ===
MODEL_NAME=Qwen/Qwen3-8B
MAX_MODEL_LEN=8192
GPU_MEM_UTIL=0.9

# === Worker Capabilities ===
# These are advertised to the broker for job matching
WORKER_CAPACITY=4
COMPUTE_TYPE=nvidia-8.9
GPU_MODEL=RTX-4090
GPU_MEMORY_GB=24
WORKER_REGION=us-west-2
MAX_CONTEXT_WINDOW=128000
